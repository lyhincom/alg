#include <iostream>
#include <string>
using namespace std;
int main()
{
	int n;
	cin >> n;
	
	if(n == 1) {
		return 
	}
	
	cout << "The next number for the number " << n << " is " << (n+1) << "." << endl;
	cout << "The previous number for the number " << n << " is " << (n-1) << "." << endl;
	return 0;
}